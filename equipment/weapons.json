  },
  "masteryProperties": {
    "cleave": "Hit second creature within 5 feet on successful hit",
    "graze": "Deal ability modifier damage even on miss",
    "nick": "Make Light weapon extra attack as part of Attack action",
    "push": "Push Large or smaller creature up to 10 feet away",
    "sap": "Target has disadvantage on next attack roll",
    "slow": "Reduce target's speed by 10 feet until start of your next turn",
    "topple": "Force Constitution save or target becomes Prone",
    "vex": "Gain advantage on next attack roll against same target"
