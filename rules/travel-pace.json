{
  "id": "travel-pace",
  "name": "Travel Pace and Overland Movement",
  "description": "Rules for character travel speeds, terrain effects, and navigation over overland distances",
  "sections": {
    "overview": {
      "title": "Travel Pace",
      "description": "A group of characters can travel overland at a Normal, Fast, or Slow pace",
      "mechanics": "During any journey stage, the predominant terrain determines the characters' maximum travel pace",
      "factor": "Certain factors can affect a group's travel pace"
    },
    "good_roads": {
      "title": "Good Roads",
      "description": "The presence of a good road increases the group's maximum pace by one step",
      "examples": [
        "Slow to Normal",
        "Normal to Fast"
      ]
    },
    "slower_travelers": {
      "title": "Slower Travelers",
      "description": "The group must move at a Slow pace if any group member's Speed is reduced to half or less of normal"
    },
    "extended_travel": {
      "title": "Extended Travel",
      "description": "Characters can push themselves to travel for more than 8 hours per day, at the risk of tiring",
      "mechanics": {
        "frequency": "At the end of each additional hour of travel beyond 8 hours",
        "requirement": "Each character must succeed on a Constitution saving throw or gain 1 Exhaustion level",
        "dc_progression": {
          "base": 10,
          "additional": "Plus 1 for each hour past 8 hours"
        }
      }
    },
    "special_movement": {
      "title": "Special Movement",
      "description": "If a party can travel at a high Speed for an extended time",
      "examples": [
        "Wind Walk spell",
        "Carpet of Flying magic item"
      ],
      "translation_rules": {
        "miles_per_hour": "Speed ÷ 10",
        "miles_per_day": "Miles per hour × number of hours traveled (typically 8)",
        "fast_pace": "Miles per day × 1⅓ (round down)",
        "slow_pace": "Miles per day × 2/3 (round down)"
      },
      "terrain_bypass": "If the characters are flying or their special movement allows them to ignore Difficult Terrain, they can move at a Fast pace regardless of the terrain"
    },
    "vehicles": {
      "title": "Vehicles",
      "description": "Characters traveling in a vehicle use the vehicle's speed in miles per hour",
      "mechanics": "They don't choose a travel pace; their speed is determined by the vehicle"
    },
