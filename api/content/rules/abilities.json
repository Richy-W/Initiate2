{
  "title": "The Six Abilities",
  "description": "Core character attributes that measure physical and mental characteristics",
  "version": "2024",
  "overview": {
    "description": "All creatures—characters and monsters—have six abilities that measure physical and mental characteristics.",
    "universality": "These abilities apply to all creatures in the game"
  },
  "abilities": [
    {
      "name": "Strength",
      "abbreviation": "STR",
      "measures": "Physical might",
      "category": "Physical",
      "description": "Raw physical power and muscle"
    },
    {
      "name": "Dexterity", 
      "abbreviation": "DEX",
      "measures": "Agility, reflexes, and balance",
      "category": "Physical",
      "description": "Nimbleness, quick reactions, and coordination"
    },
    {
      "name": "Constitution",
      "abbreviation": "CON", 
      "measures": "Health and stamina",
      "category": "Physical",
      "description": "Endurance, vitality, and life force"
    },
    {
      "name": "Intelligence",
      "abbreviation": "INT",
      "measures": "Reasoning and memory", 
      "category": "Mental",
      "description": "Logical thinking, education, and recall"
    },
    {
      "name": "Wisdom",
      "abbreviation": "WIS",
      "measures": "Perceptiveness and mental fortitude",
      "category": "Mental", 
      "description": "Awareness, insight, and willpower"
    },
    {
      "name": "Charisma",
      "abbreviation": "CHA",
      "measures": "Confidence, poise, and charm",
      "category": "Mental",
      "description": "Force of personality and social presence"
    }
  ],
  "ability_scores": {
    "description": "Each ability has a score from 1 to 20, although some monsters have a score as high as 30. The score represents the magnitude of an ability.",
    "range": {
      "minimum": 1,
      "standard_maximum": 20,
      "monster_maximum": 30
    },
    "score_meanings": [
      {
        "score": 1,
        "meaning": "This is the lowest a score can normally go. If an effect reduces a score to 0, that effect explains what happens."
      },
      {
        "score_range": "2–9",
        "meaning": "This represents a weak capability."
      },
      {
        "score_range": "10–11", 
        "meaning": "This represents the human average."
      },
      {
        "score_range": "12–19",
        "meaning": "This represents a strong capability."
