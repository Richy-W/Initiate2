      {
        "score": 20,
        "meaning": "This is the highest an adventurer's score can go unless a feature says otherwise."
      },
      {
        "score_range": "21–29",
        "meaning": "This represents an extraordinary capability."
      },
      {
        "score": 30,
        "meaning": "This is the highest a score can go."
      }
    ]
  },
