# Django Backend Environment Variables

# Debug mode (set to False in production)
DEBUG=True

# Secret key for Django (generate a new one for production)
SECRET_KEY=django-insecure-development-key-change-in-production

# Database configuration (SQLite for development, PostgreSQL for production)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# PostgreSQL settings (uncomment for production)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=dnd_webapp
# DB_USER=dnduser
# DB_PASSWORD=your_password
# DB_HOST=localhost
# DB_PORT=5432

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS settings for frontend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_ALL_ORIGINS=False

# JWT settings
JWT_SECRET_KEY=jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# Email settings (for password reset)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Redis settings (for production)
# REDIS_URL=redis://localhost:6379/0

# Static files
STATIC_URL=/static/
STATIC_ROOT=static/

# Media files
MEDIA_URL=/media/
MEDIA_ROOT=media/

# Channels settings (for WebSocket)
CHANNEL_LAYERS_BACKEND=channels.layers.InMemoryChannelLayer